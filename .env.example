GOOGLE_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MAX_BUDGET_USD=10.0
CLIENT_BASE_RATE=5%
CRAWLER_MAX_CASHBACK_PCT=30
CRAWLER_MAX_COMPETITORS=12
# Change detection — 5%→12% triggers spike when delta >= SPIKE_MIN_POINTS (default 2)
CRAWLER_SPIKE_MIN_POINTS=2.0
CRAWLER_SPIKE_MIN_RATIO=1.2
CRAWLER_DOM_CHANGE_THRESHOLD=0.88

# Phase C — Autonomous crawler / radar
CRAWLER_WORKERS=3
CRAWLER_VISION_ENABLED=true
# Visual intelligence: always | sparse (<3 DOM offers) | off
CRAWLER_VISUAL_MODE=always
CRAWLER_VISION_MODEL=gemini-2.0-flash
CRAWLER_PHASH_MAX_DISTANCE=14
# Optional local OCR (requires tesseract binary + pip install pytesseract)
CRAWLER_TESSERACT_ENABLED=false

# Enterprise intelligence
CRAWLER_ANOMALY_Z_THRESHOLD=2.5
CRAWLER_ANOMALY_HARD_RATIO=3.0
CRAWLER_PROXIES=
# Example: http://user:pass@proxy1:8080,http://proxy2:8080
RADAR_RUN_PIPELINE=false

# Adaptive autonomous crawling
# Comma-separated merchants; policy auto-adds HOT/HIGH-risk slugs
CRAWLER_WATCHLIST=Myntra,Ajio,Amazon,Nykaa,Flipkart
# Set true to always run analyst+strategist after every crawl (higher cost)
SWARM_ALWAYS_PIPELINE=false
